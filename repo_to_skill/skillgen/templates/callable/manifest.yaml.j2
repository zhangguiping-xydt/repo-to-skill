name: {{ slug }}
version: 0.1.0
kind: callable-capability
summary: {{ summary | tojson }}

# A callable-capability pack does not describe code for an agent to read; it lets
# an agent invoke an interface that already exists in a running system.
runtime:
  requires_live_system: true
  transport: http
  method: {{ http_method }}
  endpoint_env: {{ endpoint_env }}

auth:
  required: true
  type: bearer
  token_env: {{ token_env }}

safety:
  dry_run_default: true
  network: requires-explicit-endpoint
  dependency_install: disabled
  target_repository_writes: disabled
  side_effects: {{ side_effects }}

# Provenance: where in the analyzed repository this capability was lifted from.
source:
  stack: {{ stack }}
  framework: {{ framework }}
  handler: {{ handler_path | tojson }}
  handler_symbol: {{ handler_symbol | tojson }}
  business_method: {{ (business_method or "unknown") | tojson }}
  input_model: {{ request_model | tojson }}
  output_model: {{ response_model | tojson }}

generated_by: {{ generated_by }}
