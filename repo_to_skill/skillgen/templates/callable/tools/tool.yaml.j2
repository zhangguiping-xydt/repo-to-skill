# Machine-readable tool contract. An agent runtime loads this to learn the tool
# exists, what it accepts, what it returns, and how to invoke it. The shape
# mirrors common agent tool/function schemas so it is portable across runtimes.

name: {{ tool_name }}
description: {{ description | tojson }}

invocation:
  transport: http
  method: {{ http_method }}
  endpoint_env: {{ endpoint_env }}
  body: json
  auth:
    type: bearer
    token_env: {{ token_env }}

input_schema:
  type: object
{% if request_body_required %}
  required: [{{ request_body_required | join(", ") }}]
{% endif %}
  properties:
{% for field in request_body_fields %}
    {{ field.wire }}:
      type: {{ field.schema_type }}
{% if field.is_bool %}
      default: false
{% endif %}
      description: {{ field.description | tojson }}
{% else %}
    {}  # TODO: request payload could not be resolved from source; pass --json-body.
{% endfor %}
{% if request_path_fields %}
# Path parameters are substituted into {{ '{{param}}' }} placeholders in the
# endpoint URL; they are NOT sent in the JSON body.
path_parameters:
{% for field in request_path_fields %}
  {{ field.wire }}:
    type: {{ field.schema_type }}
    required: {{ field.required | lower }}
    description: {{ field.description | tojson }}
{% endfor %}
{% endif %}

output_schema:
  type: object
  properties:
{% for field in response_fields %}
    {{ field.wire }}:
      type: {{ field.schema_type }}
      description: {{ field.description | tojson }}
{% else %}
    {}  # TODO: response payload could not be resolved from source.
{% endfor %}

# Field names are kept identical to the source models so the JSON sent and
# received matches the live interface and stays verifiable against code.
mapping:
  input_model: {{ request_model | tojson }}
  output_model: {{ response_model | tojson }}
